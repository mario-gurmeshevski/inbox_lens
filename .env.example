IMAP_SERVER=imap.gmail.com

# Web Dashboard (optional)
WEB_HOST=0.0.0.0
WEB_PORT=8000
# HOST_IP=                    # Auto-detected by `make up` for network access display

# Tailscale (optional - for remote access via your tailnet)
# Generate one at https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxx

# Serve the dashboard over HTTPS via `tailscale serve` (tailnet-only).
# TS_SERVE_HTTPS=true

# Authentication (optional)
# SESSION_COOKIE_SECURE=false   # set true when serving over HTTPS (reverse proxy)
# SESSION_COOKIE_MAX_AGE=2592000 # session lifetime in seconds (default 30 days)
