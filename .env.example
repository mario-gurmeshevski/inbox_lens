IMAP_SERVER=imap.gmail.com
DB_PATH=emails.db
KEYWORDS_FILE=keywords.json  # Local dev only; Docker sets its own via image ENV
# SECRET_KEY_PATH=.secret.key  # Auto-generated on first login

# Web Dashboard (optional)
WEB_HOST=0.0.0.0
WEB_PORT=8000
# HOST_IP=                    # Auto-detected by `make up` for network access display

# Telegram Bot (optional - only needed for bot.py)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ALLOWED_CHAT_IDS=your_chat_id_here
ALERT_MIN_PRIORITY=7
